# Givebear origin. Use https://givebear.io against production, or
# http://localhost:3000 if you run the dashboard locally.
GIVEBEAR_BASE_URL=https://givebear.io

# From Dashboard -> Developers -> OAuth apps. Register an app whose redirect URI
# is http://localhost:4000/api/oauth/callback and that can request the scopes
# donations:read, reference:read, webhooks:write, offline_access.
GIVEBEAR_CLIENT_ID=
GIVEBEAR_CLIENT_SECRET=

# Must EXACTLY match a redirect URI on the app above.
OAUTH_REDIRECT_URI=http://localhost:4000/api/oauth/callback

# Any long random string; signs the demo's session cookie.
SESSION_SECRET=change-me-to-something-random

# Public URL of THIS demo so Givebear can deliver webhooks (e.g. an ngrok or
# cloudflared tunnel pointing at localhost:4000). Leave blank to skip webhooks.
PUBLIC_URL=
